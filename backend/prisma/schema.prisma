// Prisma Schema file for PostgreSQL Database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id                  Int              @id @default(autoincrement())
  name                String           @db.VarChar(255)
  sku                 String           @unique @db.VarChar(100)
  available_quantity  Int              @default(0)
  low_stock_threshold Int              @default(10)
  cost_price          Decimal          @db.Decimal(10, 2)
  supplier_name       String           @default("Global Supplies Co.") @db.VarChar(255)
  category            String?          @default("General") @db.VarChar(100)
  created_at          DateTime         @default(now()) @db.Timestamptz()
  updated_at          DateTime         @default(now()) @updatedAt @db.Timestamptz()
  reorders            ReorderRequest[]

  @@map("products")
}

model ReorderRequest {
  id               Int       @id @default(autoincrement())
  product_id       Int
  product_name     String    @db.VarChar(255)
  quantity_ordered Int
  unit_cost        Decimal   @db.Decimal(10, 2)
  total_cost       Decimal   @db.Decimal(10, 2)
  supplier_name    String    @db.VarChar(255)
  reorder_status   String    @default("PENDING") @db.VarChar(50)
  is_high_value    Boolean   @default(false)
  otp_code         String?   @db.VarChar(10)
  otp_expires_at   DateTime? @db.Timestamptz()
  created_at       DateTime  @default(now()) @db.Timestamptz()
  updated_at       DateTime  @default(now()) @updatedAt @db.Timestamptz()
  product          Product   @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([reorder_status])
  @@index([product_id])
  @@map("reorder_requests")
}
